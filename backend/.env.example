# Hugging Face API Token (required for generation via Inference API)
HF_API_TOKEN=hf_your_token_here

# Model Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
GENERATION_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Chunking
CHUNK_SIZE=600
CHUNK_OVERLAP=120

# Retrieval
TOP_K=5
SCORE_THRESHOLD=0.3
MAX_CONTEXT_TOKENS=3000

# Paths
DATA_DIR=./data
FAISS_INDEX_PATH=./data/faiss_index

# Logging
LOG_LEVEL=INFO
